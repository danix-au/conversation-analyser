# Required Dataverse settings
DATAVERSE_URL=https://your-org.crm.dynamics.com

# Prefer the Dataverse entity set name (usually plural).
# Example: conversationtranscripts
DATAVERSE_TABLE=ConversationTranscript

# Optional: comma-separated list of columns to pull. Leave blank for all columns.
DATAVERSE_SELECT=

# Optional output/state settings
OUTPUT_DIR=output
DELTA_STATE_FILE=.state/dataverse_delta_state.json

# Optional: include deleted records in change tracking output (true/false)
INCLUDE_DELETES=false

# Optional Entra enrichment auth mode for transcript analytics:
# - az  : use current Azure CLI login
# - app : use app registration credentials below
ENTRA_AUTH_MODE=az

# Required only when ENTRA_AUTH_MODE=app
ENTRA_TENANT_ID=<tenant-guid>
ENTRA_CLIENT_ID=<app-client-id-guid>
ENTRA_CLIENT_SECRET=<app-client-secret>
